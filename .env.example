# ABPI API
ABPI_API_KEY=
ABPI_BASE_URL=https://abpi.se/api

# App
OUTPUT_DIR=./data/exports
SCB_CACHE_PATH=./data/scb_cache.txt
DATABASE_URL=sqlite:///./data/pipefire.db
SECRET_KEY=change_me_to_random_string

# Gmail OAuth — get from Google Cloud Console
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/auth/gmail/callback
GMAIL_TOKEN_PATH=./data/token.json

# Sender identity
SENDER_NAME=Adam
GMAIL_SEND_AS=

# Pipeline tuning
ABPI_REQUEST_DELAY=0.15
ABPI_TIMEOUT=10
SCB_CACHE_TTL=604800
FOLLOWUP_DAY_1=5
FOLLOWUP_DAY_2=10
FOLLOWUP_COLD=15
